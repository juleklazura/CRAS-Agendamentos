# ============================================
# CONFIGURAÇÃO PARA VERCEL + POSTGRESQL NEON
# ============================================
# ⚠️ IMPORTANTE: Estas variáveis devem ser configuradas no painel do Vercel!
# Dashboard → Settings → Environment Variables

# ========== PostgreSQL Neon (BACKEND - Configure no Vercel) ==========
# Connection string do PostgreSQL Neon (pooled - para a aplicação)
# Obtenha em: https://console.neon.tech → Connection Details
DATABASE_URL=postgresql://usuario:senha@ep-xxx.us-east-2.aws.neon.tech/cras?sslmode=require

# Connection string direta (para migrações Prisma)
DATABASE_URL_UNPOOLED=postgresql://usuario:senha@ep-xxx.us-east-2.aws.neon.tech/cras?sslmode=require

# ========== JWT Secrets (BACKEND - Configure no Vercel) ==========
# Gerar com: openssl rand -hex 32
JWT_SECRET=GERAR_STRING_ALEATORIA_64_CARACTERES
REFRESH_TOKEN_SECRET=GERAR_OUTRA_STRING_ALEATORIA_64_CARACTERES

# ========== Encryption (BACKEND - Configure no Vercel) ==========
# Gerar com: openssl rand -hex 16
ENCRYPTION_KEY=GERAR_STRING_ALEATORIA_32_CARACTERES

# ========== CORS (BACKEND - Configure no Vercel) ==========
# URL do frontend (deixe vazio para usar mesmo domínio no Vercel)
FRONTEND_URL=http://localhost:5173

# ========== Admin Inicial (BACKEND - Configure no Vercel) ==========
ADMIN_MATRICULA=admin
ADMIN_PASSWORD=GERAR_COM_COMANDO_ABAIXO
# Gerar: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"

# ========== Ambiente ==========
NODE_ENV=production

# ========== Frontend (NÃO NECESSÁRIO NO VERCEL - usa /api mesmo domínio) ==========
# Apenas para desenvolvimento local
# VITE_API_BASE_URL=/api

# ============================================
# 📋 PASSO A PASSO DEPLOY VERCEL
# ============================================
#
# 1. PostgreSQL Neon (https://console.neon.tech):
#    - Criar projeto gratuito (Free Tier - 512MB)
#    - Copiar Connection String (pooled)
#    - Copiar Connection String (unpooled/direct)
#
# 2. Gerar Secrets:
#    openssl rand -hex 32  # JWT_SECRET
#    openssl rand -hex 32  # REFRESH_TOKEN_SECRET  
#    openssl rand -hex 16  # ENCRYPTION_KEY
#
# 3. Push para GitHub:
#    git add .
#    git commit -m "feat: migração para PostgreSQL Neon"
#    git push origin main
#
# 4. Deploy no Vercel (https://vercel.com):
#    - Import Git Repository
#    - Framework Preset: Vite
#    - Adicionar Environment Variables:
#      * DATABASE_URL
#      * DATABASE_URL_UNPOOLED
#      * JWT_SECRET
#      * REFRESH_TOKEN_SECRET
#      * ENCRYPTION_KEY
#      * FRONTEND_URL (deixe vazio ou use a URL do Vercel)
#      * ADMIN_EMAIL
#      * ADMIN_PASSWORD
#      * NODE_ENV=production
#    - Deploy
#
# 5. Testar:
#    https://seu-projeto.vercel.app/api/health
#
# 6. Criar admin inicial:
#    npx prisma db push && node backend/scripts/createAdmin.js
#
# 7. Trocar senha do admin após primeiro login!
#
# ============================================

