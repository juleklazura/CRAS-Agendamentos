# =============================================================================
# SISTEMA DE AGENDAMENTOS CRAS - Backend Environment Variables
# =============================================================================
# ⚠️ IMPORTANTE: Este é um arquivo de EXEMPLO. NÃO coloque valores reais aqui!
# 
# 1. Copie este arquivo: cp .env.example .env
# 2. Edite o arquivo .env com seus valores reais
# 3. NUNCA commite o arquivo .env no Git
# =============================================================================

# -----------------------------------------------------------------------------
# 🗄️ POSTGRESQL NEON CONFIGURATION
# -----------------------------------------------------------------------------
# Connection string do PostgreSQL Neon (pooled - para a aplicação)
# Obtenha em: https://console.neon.tech → Connection Details
#
# Para PostgreSQL Neon (RECOMENDADO):
DATABASE_URL=postgresql://[username]:[password]@[endpoint].neon.tech/[database]?sslmode=require
# Exemplo: postgresql://cras_admin:SuaSenha123@ep-cool-fire-123456.us-east-2.aws.neon.tech/cras?sslmode=require

# Connection string direta (para migrações Prisma - sem pooling)
DATABASE_URL_UNPOOLED=postgresql://[username]:[password]@[endpoint].neon.tech/[database]?sslmode=require

# ⚠️ SEGURANÇA:
# - Senha deve ter no mínimo 20 caracteres (letras, números, símbolos)
# - SSL é obrigatório (sslmode=require)
# - Use o endpoint pooled para a aplicação (melhor performance)
# - Use o endpoint unpooled/direct apenas para migrações Prisma

# -----------------------------------------------------------------------------
# 🔐 JWT (JSON Web Tokens) CONFIGURATION
# -----------------------------------------------------------------------------
# Secret para tokens de acesso (Access Tokens)
JWT_SECRET=GERAR_COM_COMANDO_ABAIXO_128_CARACTERES_HEXADECIMAIS
# Gerar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Secret para tokens de atualização (Refresh Tokens)
JWT_REFRESH_SECRET=GERAR_COM_COMANDO_ABAIXO_128_CARACTERES_DIFERENTES
# Gerar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ⚠️ SEGURANÇA:
# - Cada secret DEVE ter no mínimo 64 caracteres (recomendado: 128)
# - JWT_SECRET e JWT_REFRESH_SECRET DEVEM ser DIFERENTES
# - NUNCA reutilize secrets entre ambientes (dev, staging, prod)
# - Rotacione secrets a cada 3-6 meses em produção
# - Guarde backup dos secrets em vault/cofre seguro

# -----------------------------------------------------------------------------
# 🔒 DATA ENCRYPTION CONFIGURATION
# -----------------------------------------------------------------------------
# Chave de criptografia para dados sensíveis (CPF, nomes, telefones)
ENCRYPTION_KEY=sua_chave_de_criptografia_forte_aqui_minimo_32_caracteres

# ⚠️ CRÍTICO - LEIA COM ATENÇÃO:
# - Esta chave é usada para criptografar dados PERMANENTEMENTE no banco de dados
# - Se ALTERAR esta chave, TODOS os dados criptografados ficarão ILEGÍVEIS para sempre!
# - Use uma string aleatória forte (mínimo 32 caracteres)
# - Algoritmo usado: AES-256-CBC
# - NUNCA altere após o primeiro registro no banco!
# - Faça backup seguro desta chave ANTES de qualquer migração!
# 
# Gerar chave forte:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Dados que serão criptografados:
# ✅ CPF dos usuários
# ✅ Nomes completos
# ✅ Números de telefone
# ✅ CPF dos agendamentos

# -----------------------------------------------------------------------------
# 🌐 SERVER CONFIGURATION
# -----------------------------------------------------------------------------
# Porta onde o servidor Express irá rodar
PORT=5000

# Ambiente de execução (development, production, test)
NODE_ENV=development

# URL do frontend (para configuração CORS)
FRONTEND_URL=http://localhost:5173
# Em produção: FRONTEND_URL=https://seudominio.com.br

# Trust Proxy - Habilitar APENAS se houver proxy reverso (Nginx, CloudFlare, ALB)
# ⚠️ NÃO HABILITAR sem proxy real (permite IP spoofing)
TRUST_PROXY=false
# Em produção com Nginx/CloudFlare: TRUST_PROXY=true

# ⚠️ IMPORTANTE:
# - Em produção, NODE_ENV DEVE ser "production"
# - FRONTEND_URL em produção DEVE ser HTTPS
# - Nunca use http:// em produção (apenas https://)
# - TRUST_PROXY deve ser true APENAS se houver proxy reverso

# -----------------------------------------------------------------------------
# 📝 LOGGING CONFIGURATION (opcional)
# -----------------------------------------------------------------------------
# Nível de log: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Diretório para salvar logs
LOG_DIR=logs

# Dias para manter logs antigos
LOG_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# 🚦 RATE LIMITING (opcional - valores padrão já configurados)
# -----------------------------------------------------------------------------
# Máximo de requisições por janela de tempo
RATE_LIMIT_MAX=20

# Janela de tempo em minutos
RATE_LIMIT_WINDOW=15

# -----------------------------------------------------------------------------
# 🔐 SESSION CONFIGURATION (opcional)
# -----------------------------------------------------------------------------
# Tempo de expiração do Access Token (em segundos)
JWT_EXPIRES_IN=28800  # 8 horas

# Tempo de expiração do Refresh Token (em segundos)
JWT_REFRESH_EXPIRES_IN=604800  # 7 dias

# -----------------------------------------------------------------------------
# 📧 EMAIL CONFIGURATION (futuro - não implementado ainda)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-de-app
# SMTP_FROM=noreply@seudominio.com.br

# -----------------------------------------------------------------------------
# 👤 ADMIN INITIAL SETUP (usado apenas pelo script createAdmin.js)
# -----------------------------------------------------------------------------
# Matrícula e senha do primeiro usuário administrador
# ⚠️ Altere imediatamente após o primeiro login!
ADMIN_MATRICULA=admin
ADMIN_PASSWORD=GERAR_COM_COMANDO_ABAIXO
# Gerar: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"

# -----------------------------------------------------------------------------
# CHECKLIST ANTES DE RODAR EM PRODUÇÃO
# -----------------------------------------------------------------------------
# 
# ✅ Todas as variáveis preenchidas com valores reais
# ✅ JWT_SECRET gerado com 128 caracteres (crypto.randomBytes(64))
# ✅ JWT_REFRESH_SECRET gerado e DIFERENTE do JWT_SECRET
# ✅ ENCRYPTION_KEY gerada e BACKUP feito em local seguro
# ✅ ADMIN_PASSWORD definido com senha forte (alterar no 1º login!)
# ✅ NODE_ENV=production
# ✅ FRONTEND_URL com HTTPS e domínio real
# ✅ Arquivo .env NÃO está no Git (.gitignore configurado)
# ✅ Permissões do arquivo .env: chmod 600 .env
# ✅ Firewall configurado (apenas portas necessárias abertas)
# ✅ SSL/TLS configurado (Let's Encrypt)
# ✅ Backup da ENCRYPTION_KEY em vault/cofre
# ✅ Processo de rotação de secrets documentado
# 
# =============================================================================

